# EJEMPLO 27: Transparencia con "transparency"
#
# "transparency" va de 0 (totalmente solido, se ve normal) a 1
# (totalmente invisible). Los valores intermedios, como 0.5, hacen que
# el objeto se vea semi-transparente, como un fantasma o un vidrio.

entity GhostWall {
    transparency = 0.6
    collision = false
}
