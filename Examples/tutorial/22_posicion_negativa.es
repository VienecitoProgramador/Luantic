# EJEMPLO 22: Posiciones negativas (abajo del nivel del suelo)
#
# Los numeros negativos funcionan igual que en matematica: un valor
# negativo en la posicion vertical (el segundo numero) pone el objeto
# por DEBAJO del punto cero del mapa. Sirve para trampas escondidas,
# subsuelos, o efectos de objetos que caen.

entity HiddenTrap {
    position = (0, -10, 0)
}
