# EJEMPLO 24: Color con nombre (la forma mas simple)
#
# EntityScript reconoce 12 nombres de color listos para usar: red, blue,
# green, yellow, white, black, gray, orange, purple, pink, brown, cyan.
# Basta con escribir el nombre, sin comillas.

entity RubyGem {
    color = red
}

entity SapphireGem {
    color = blue
}
