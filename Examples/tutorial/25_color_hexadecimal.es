# EJEMPLO 25: Color exacto con codigo hexadecimal
#
# Cuando necesitas un color mas especifico que los 12 nombres basicos
# (por ejemplo, un dorado exacto para una moneda premium), podes usar un
# codigo hexadecimal entre comillas, con el formato "#RRGGBB" (RGB en
# hexadecimal, el mismo formato que usan los editores de diseño).

entity GoldenTrophy {
    color = "#FFD700"
}
