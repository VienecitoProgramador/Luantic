# EJEMPLO 21: Ubicar un objeto en el mundo con "position"
#
# "position" define donde aparece el objeto en el espacio 3D del juego,
# usando tres numeros entre parentesis: (izquierda/derecha, arriba/abajo,
# adelante/atras). Estos tres numeros juntos se llaman un "Vector3" en
# Roblox, pero en EntityScript los escribis simple, como una lista.

entity FloatingCoin {
    position = (0, 5, 0)
}
